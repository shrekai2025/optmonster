APP_ENV=dev
APP_ENV_FILE=config/environments/dev.env
API_PORT=8000
POSTGRES_DB=optmonster
POSTGRES_USER=optmonster
POSTGRES_PASSWORD=optmonster
POSTGRES_PORT=5432
REDIS_PORT=6379
DATABASE_URL=postgresql+asyncpg://optmonster:optmonster@postgres:5432/optmonster
REDIS_URL=redis://redis:6379/0
CONFIG_DIR=config/accounts
COOKIE_DIR=config/cookies
WORKER_POLL_INTERVAL_SECONDS=30
SCHEDULED_FETCH_INTERVAL_SECONDS=300
FETCH_LIMIT_DEFAULT=20
LOCK_TTL_SECONDS=300
PAUSE_AFTER_FAILURES=3
BACKOFF_BASE_SECONDS=30
BACKOFF_MAX_SECONDS=900
BROWSER_FALLBACK_ENABLED=false
TWIKIT_LOCALE=en-US
APP_TIMEZONE=UTC
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_ID=
