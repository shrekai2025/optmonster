APP_ENV=prod
APP_ENV_FILE=config/environments/prod.env
API_PORT=8000
POSTGRES_DB=optmonster
POSTGRES_USER=optmonster
POSTGRES_PASSWORD=replace-me
POSTGRES_PORT=5432
REDIS_PORT=6379
DATABASE_URL=postgresql+asyncpg://optmonster:replace-me@postgres:5432/optmonster
REDIS_URL=redis://redis:6379/0
CONFIG_DIR=config/accounts
COOKIE_DIR=config/cookies
WORKER_POLL_INTERVAL_SECONDS=30
SCHEDULED_FETCH_INTERVAL_SECONDS=300
FETCH_LIMIT_DEFAULT=20
FETCH_RECENT_WINDOW_HOURS=24
FETCH_LATEST_FIRST=true
FETCH_INCLUDE_REPLIES=true
FETCH_INCLUDE_RETWEETS=true
POPULAR_TWEET_MIN_VIEWS=100000
POPULAR_TWEET_MIN_LIKES=500
POPULAR_TWEET_MIN_RETWEETS=50
POPULAR_TWEET_MIN_REPLIES=20
LOCK_TTL_SECONDS=300
PAUSE_AFTER_FAILURES=3
BACKOFF_BASE_SECONDS=30
BACKOFF_MAX_SECONDS=900
BROWSER_FALLBACK_ENABLED=false
TWIKIT_LOCALE=en-US
APP_TIMEZONE=UTC
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://your-provider.example/v1
LLM_API_KEY=replace-me
LLM_MODEL_ID=replace-me
AI_ENABLED=false
